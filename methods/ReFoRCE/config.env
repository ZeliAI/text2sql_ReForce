# Lite SQLite run config. Safe to edit and commit; keep secrets in .env.

# Supported models: kimi-k2.6, moonshot-v1-128k.
# Note: moonshot-v1-128k does not support thinking mode; keep THINK_OR_NOT=false.
# LLM_PROVIDER can be moonshot, openai, openai_compatible, local, or empty.
LLM_PROVIDER=moonshot
LLM_MODEL=moonshot-v1-128k
LLM_TEMPERATURE=0.6
LLM_TIMEOUT=120
LLM_MAX_TOKENS=4096
THINK_OR_NOT=false
THINKING_UNSUPPORTED_MODELS=moonshot-v1-128k
LLM_RETRY_MAX=8
LLM_RETRY_BASE_SECONDS=2
LLM_RETRY_MAX_SECONDS=30
LLM_TEST_MODE=false

NUM_WORKERS=1
MAX_ITER=1
TASK_LIMIT=10
TASK_OFFSET=0
DO_VOTE=false
NUM_VOTES=3
RANDOM_VOTE_FOR_TIE=false
FINAL_CHOOSE=false

OUTPUT_PATH=output/moonshot-v1-128k-lite-sqlite-10-no-thinking
ADD_TIMESTAMP=true
