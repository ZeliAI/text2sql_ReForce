# Lite SQLite run config. Safe to edit and commit; keep secrets in .env.

# Supported models: kimi-k2.6, moonshot-v1-128k.
# Note: moonshot-v1-128k does not support thinking mode; keep THINK_OR_NOT=false.
LLM_MODEL=kimi-k2.6
LLM_TEMPERATURE=0.6
LLM_TIMEOUT=120
LLM_MAX_TOKENS=4096
THINK_OR_NOT=false

NUM_WORKERS=1
MAX_ITER=1
TASK_LIMIT=3
TASK_OFFSET=10

OUTPUT_PATH=output/kimi-k2.6-lite-sqlite-3tasks-offset10-no-thinking
ADD_TIMESTAMP=true
