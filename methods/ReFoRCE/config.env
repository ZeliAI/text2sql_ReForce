# Lite SQLite run config. Safe to edit and commit; keep secrets in .env.

# Supported models: kimi-k2.6, moonshot-v1-128k, moonshot-v1-64k, claude-opus-4-6 (via simpleai, default base URL https://key.simpleai.com.cn/v1). simpleai optional models: claude-sonnet-4-6, claude-haiku-4-5-20251001.
# Note: moonshot-v1-128k and moonshot-v1-64k do not support thinking mode; keep THINK_OR_NOT=false.
# LLM_PROVIDER can be moonshot, simpleai, openai, openai_compatible, local, or empty.
LLM_PROVIDER=moonshot
LLM_MODEL=moonshot-v1-128k
LLM_TEMPERATURE=0.6
LLM_TIMEOUT=120
LLM_MAX_TOKENS=4096
THINK_OR_NOT=false
THINKING_UNSUPPORTED_MODELS=moonshot-v1-128k,moonshot-v1-64k
LLM_RETRY_MAX=8
LLM_RETRY_BASE_SECONDS=2
LLM_RETRY_MAX_SECONDS=30
LLM_TEST_MODE=false
DO_SCHEMA_SUMMARY=true
SCHEMA_SUMMARY_MODEL=
SELECTOR_MODEL=

NUM_WORKERS=1
MAX_ITER=1
TASK_LIMIT=10
TASK_OFFSET=0
DO_VOTE=false
NUM_VOTES=3
RANDOM_VOTE_FOR_TIE=false
FINAL_CHOOSE=false

OUTPUT_PATH=output/moonshot-v1-128k-lite-sqlite-10-no-thinking
ADD_TIMESTAMP=true
