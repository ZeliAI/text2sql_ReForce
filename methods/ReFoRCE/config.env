# Lite SQLite run config. Safe to edit and commit; keep secrets in .env.

# Supported providers and common models:
# `moonshot`: `kimi-k2.6`, `moonshot-v1-128k`, `moonshot-v1-32k`。`kimi-k2.6` 在非思考模式下 temperature 使用 `0.6`，在思考模式下 temperature 使用 `1`，且思考模式默认走流式；`moonshot-v1-128k` 和 `moonshot-v1-32k` 不支持 thinking，保持 `THINK_OR_NOT=false`。
# `simpleai`: `claude-opus-4-6`, `claude-opus-4-7`, `claude-sonnet-4-6`, `claude-haiku-4-5-20251001`。通过 `.env` 中的 `SIMPLEAI_BASE_URL` / `SIMPLEAI_API_KEY` 配置。
# `openai`: 使用 `OPENAI_BASE_URL` / `OPENAI_API_KEY`，模型按你的 OpenAI 账号可用模型填写。
# `openai_compatible`: 使用 `OPENAI_COMPATIBLE_BASE_URL` / `OPENAI_COMPATIBLE_API_KEY`，适合第三方兼容网关。
# `local`: 使用 `LOCAL_BASE_URL` / `LOCAL_API_KEY`，适合本地部署的 OpenAI-compatible 服务。

LLM_PROVIDER=moonshot # 当前调用的 provider；可选 `moonshot`、`simpleai`、`openai`、`openai_compatible`、`local`
LLM_MODEL=moonshot-v1-128k # 当前使用的模型名；按上面的 provider 兼容模型填写
LLM_TEMPERATURE=0.6 # 采样温度；常见取值 `0`、`0.6`、`1`；`kimi-k2.6` 非思考模式建议 `0.6`，思考模式建议 `1`
LLM_TIMEOUT=120 # 单次 LLM 请求超时时间（秒）；正整数，例如 `60`、`120`、`300`
LLM_MAX_TOKENS=4096 # 单次 LLM 最大输出 token；留空表示使用服务端默认值
THINK_OR_NOT=false # 是否启用 provider 的 thinking 模式；可选 `true`、`false`；`kimi-k2.6` 在思考模式下默认走流式调用
THINKING_UNSUPPORTED_MODELS=moonshot-v1-128k,moonshot-v1-32k # 不支持 thinking 的模型列表；英文逗号分隔
LLM_RETRY_MAX=8 # 可重试错误的最大重试次数；正整数
LLM_RETRY_BASE_SECONDS=2 # 指数退避的基础等待秒数；常见取值 `1`、`2`、`5`
LLM_RETRY_MAX_SECONDS=30 # 单次重试等待的最大秒数；常见取值 `10`、`30`、`60`
KIMI_THINKING_HEARTBEAT_TIMEOUT_SECONDS=420 # `kimi-k2.6` 思考模式在进入最终答案前允许的最长 heartbeat 时长（秒）；默认 `420`
LLM_TEST_MODE=false # 是否把原始请求/响应写入调试日志；可选 `true`、`false`
DO_SCHEMA_SUMMARY=true # 是否在生成 SQL 前先做一轮 schema summary；可选 `true`、`false`
SCHEMA_SUMMARY_MODEL= # schema summary 阶段单独使用的模型；留空表示回退到 `LLM_MODEL`
SELECTOR_MODEL= # final choose / selector 阶段使用的模型；留空表示回退到主模型

NUM_WORKERS=1 # 并发处理样本数；正整数，受 API 并发额度限制
MAX_ITER=1 # self-refine 最大迭代轮数；正整数，`1` 表示只生成一轮
TASK_LIMIT=10 # 本次最多跑多少条样本；`0` 表示跑全部
TASK_OFFSET=0 # 从第几条样本开始跑；`0` 表示不跳过
DO_VOTE=false # 是否生成多个候选并执行 vote；可选 `true`、`false`
NUM_VOTES=3 # 开启 vote 时生成多少个候选；正整数，例如 `3`、`5`
RANDOM_VOTE_FOR_TIE=false # vote 打平时是否允许随机打破平局；可选 `true`、`false`
FINAL_CHOOSE=false # vote 无稳定共识时是否启用 selector 做最终选择；可选 `true`、`false`

OUTPUT_PATH= # 输出目录前缀；留空表示脚本按模型/模式/limit/offset 自动生成
ADD_TIMESTAMP=true # 是否在输出目录后自动追加时间戳；可选 `true`、`false`
